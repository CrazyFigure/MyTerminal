{
  "name": "myterminal",
  "private": true,
  "version": "0.1.0",
  "description": "A modern Rust + Tauri 2 remote terminal manager inspired by FinalShell.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host 0.0.0.0 --port 1420",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "check:web": "npm run build",
    "check:perl": "powershell -ExecutionPolicy Bypass -File ./scripts/check-perl.ps1",
    "check:rust": "powershell -ExecutionPolicy Bypass -File ./scripts/check-rust.ps1",
    "check:env": "powershell -ExecutionPolicy Bypass -File ./scripts/check-env.ps1",
    "check": "npm run check:web && npm run check:rust",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package": "npm run tauri:build"
  },
  "keywords": [
    "tauri",
    "rust",
    "terminal",
    "ssh",
    "webdav"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
